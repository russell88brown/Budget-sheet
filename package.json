{
  "name": "Budget-sheet",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^18.19.72",
    "esbuild": "^0.25.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "build:typed": "node scripts/build-typed-budget.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-tests.mjs",
    "verify": "npm run typecheck && npm run test && npm run build:typed",
    "sprint:start": "node scripts/sprint-tools.mjs start",
    "sprint:check": "node scripts/sprint-tools.mjs check",
    "pr:deploy-main": "node scripts/pr-tools.mjs deploy-main",
    "pr:test-branch": "node scripts/pr-tools.mjs test-branch"
  }
}
